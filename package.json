{
  "name": "server-cli-core",
  "version": "0.0.0",
  "description": "Project-agnostic shell for building modular Node.js CLI servers — REPL, command dispatch, module discovery, shutdown handling. Extracted from midi-daddy.",
  "main": "index.js",
  "type": "module",
  "exports": {
    ".": "./index.js",
    "./package.json": "./package.json"
  },
  "scripts": {
    "test": "NODE_OPTIONS='--experimental-vm-modules' jest",
    "test:watch": "NODE_OPTIONS='--experimental-vm-modules' jest --watch",
    "test:coverage": "NODE_OPTIONS='--experimental-vm-modules' jest --coverage",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "prepare": "husky"
  },
  "keywords": [
    "cli",
    "repl",
    "modular",
    "shell"
  ],
  "author": "",
  "license": "ISC",
  "engines": {
    "node": "^25.0.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rdgco/server-cli-core.git"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@jest/globals": "^30.2.0",
    "@stylistic/eslint-plugin": "^5.10.0",
    "eslint": "^10.2.1",
    "globals": "^17.5.0",
    "husky": "^9.1.7",
    "jest": "^30.2.0"
  },
  "jest": {
    "testEnvironment": "node",
    "transform": {},
    "roots": [
      "<rootDir>/lib",
      "<rootDir>/modules"
    ],
    "testRegex": "\\.test\\.js$",
    "testPathIgnorePatterns": [
      "/node_modules/"
    ]
  }
}
