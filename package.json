{
  "name": "server-cli-core",
  "version": "0.2.1",
  "description": "A small framework for building modular Node.js CLI servers. Provides a REPL prompt, a command-dispatch registry, module discovery, and a shutdown service — the chassis a domain-specific CLI server can layer its modules on top of.",
  "main": "index.js",
  "type": "module",
  "exports": {
    ".": "./index.js",
    "./package.json": "./package.json",
    "./lib/bootstrap.js": "./lib/bootstrap.js",
    "./lib/command-registry.js": "./lib/command-registry.js",
    "./lib/command-interceptors.js": "./lib/command-interceptors.js",
    "./lib/shell-builtins.js": "./lib/shell-builtins.js",
    "./lib/shutdown-service.js": "./lib/shutdown-service.js",
    "./lib/status-contract.js": "./lib/status-contract.js",
    "./lib/session-state.js": "./lib/session-state.js",
    "./lib/sqlite-connection.js": "./lib/sqlite-connection.js",
    "./lib/telemetry-context.js": "./lib/telemetry-context.js",
    "./lib/event-broadcaster.js": "./lib/event-broadcaster.js",
    "./lib/history.js": "./lib/history.js",
    "./lib/files.js": "./lib/files.js",
    "./lib/format.js": "./lib/format.js",
    "./lib/errors.js": "./lib/errors.js",
    "./lib/confirm.js": "./lib/confirm.js",
    "./lib/prompt.js": "./lib/prompt.js",
    "./lib/module-registry.js": "./lib/module-registry.js",
    "./modules/log/logger.js": "./modules/log/logger.js",
    "./modules/log/log-commands.js": "./modules/log/log-commands.js",
    "./modules/help/help-commands.js": "./modules/help/help-commands.js",
    "./modules/history/history-commands.js": "./modules/history/history-commands.js",
    "./modules/quit/quit-commands.js": "./modules/quit/quit-commands.js"
  },
  "scripts": {
    "test": "NODE_OPTIONS='--experimental-vm-modules' jest",
    "test:watch": "NODE_OPTIONS='--experimental-vm-modules' jest --watch",
    "test:coverage": "NODE_OPTIONS='--experimental-vm-modules' jest --coverage",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "prepare": "husky"
  },
  "keywords": [
    "cli",
    "repl",
    "modular",
    "shell"
  ],
  "author": "",
  "license": "ISC",
  "engines": {
    "node": "^26.0.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rdgco/server-cli-core.git"
  },
  "dependencies": {
    "better-sqlite3": "^12.6.2",
    "readline-sync": "^1.4.10"
  },
  "allowScripts": {
    "better-sqlite3": true
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@jest/globals": "^30.2.0",
    "@stylistic/eslint-plugin": "^5.10.0",
    "eslint": "^10.2.1",
    "globals": "^17.5.0",
    "husky": "^9.1.7",
    "jest": "^30.2.0"
  },
  "jest": {
    "testEnvironment": "node",
    "transform": {},
    "roots": [
      "<rootDir>/lib",
      "<rootDir>/modules",
      "<rootDir>/examples"
    ],
    "testRegex": "\\.test\\.js$",
    "testPathIgnorePatterns": [
      "/node_modules/"
    ],
    "collectCoverageFrom": [
      "lib/**/*.js",
      "modules/**/*.js",
      "examples/**/*.js",
      "!**/*.test.js"
    ],
    "coverageReporters": [
      "text-summary",
      "lcov",
      "json-summary"
    ]
  }
}
